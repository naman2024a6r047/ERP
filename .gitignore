# Dependency directories
node_modules/
**/node_modules/

# Environment files (contains credentials)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep .env.example files tracked
!**/.env.example

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE/Editor folders
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# OS files
desktop.ini
ehthumbs.db

# Build artifacts (generated on server via postinstall)
client/build/
dist/
out/
.next/

# Archives
*.zip
*.rar
*.tar.gz
